{
  "name": "amazfit-race-stats",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Zepp OS mini app that shows a rider's live race standing on Amazfit watches.",
  "license": "MIT",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "dev": "npx --yes @zeppos/zeus-cli@1.9.2 dev",
    "preview": "npx --yes @zeppos/zeus-cli@1.9.2 preview",
    "build": "npx --yes @zeppos/zeus-cli@1.9.2 build"
  },
  "dependencies": {
    "@zeppos/zml": "^0.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "vitest": "^4.1.10"
  }
}
